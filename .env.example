# Copy to .env for local dev (values below are safe local defaults).
# In production (Railway/Render) set these as environment variables instead.

# Generate a real one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev-only-secret-change-me

# true for local, false in production
DEBUG=true

# Comma-separated. Add your Railway/Render host in production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset locally (uses SQLite). In production set the Postgres URL:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Comma-separated origins allowed to read the API from the browser.
# Add your Vercel domain in production, e.g. https://omurravli.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Needed for the admin login over HTTPS in production, e.g. https://api.omurravli.com
CSRF_TRUSTED_ORIGINS=
